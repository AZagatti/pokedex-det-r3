		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/svelte": "^4.0.0",
		"@vitest/ui": "^1.0.0",
		"autoprefixer": "^10.4.18",
		"jsdom": "^23.0.0",
		"lefthook": "^1.5.0",
		"lucide-svelte": "^0.294.0",
		"oxlint": "^0.7.0",
		"postcss": "^8.4.32",
		"prettier": "^3.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^3.0.0",
		"tailwindcss": "^4.0.0",
